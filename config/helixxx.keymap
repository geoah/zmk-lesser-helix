 #include <behaviors.dtsi>
 #include <dt-bindings/zmk/keys.h>
 #include <dt-bindings/zmk/bt.h>
 #include <dt-bindings/zmk/rgb.h>
 #include <dt-bindings/zmk/ext_power.h>
 #include <dt-bindings/zmk/outputs.h>

 #define DEFAULT 0
 #define LWR     1
 #define RSE     2
 #define ADJ     3

/ {
       macros {
              // &bt takes two params so it can't be used directly inside a
              // hold-tap; wrap the BT pairing clear in a 0-param macro.
              bt_clr_macro: bt_clr_macro {
                     compatible = "zmk,behavior-macro";
                     #binding-cells = <0>;
                     bindings = <&bt BT_CLR>;
              };
       };

       behaviors {
              // Tap = the second param (a keycode); hold ~2s = clear the
              // current Bluetooth pairing. tap-preferred so a normal press
              // (or pressing other keys) never triggers the reset.
              // Invoke as: &btclr_ht 0 <tap-keycode>  (the 0 is a dummy
              // param for the 0-cell hold macro).
              btclr_ht: bt_clear_hold_tap {
                     compatible = "zmk,behavior-hold-tap";
                     #binding-cells = <2>;
                     tapping-term-ms = <2000>;
                     flavor = "tap-preferred";
                     bindings = <&bt_clr_macro>, <&kp>;
              };
       };

       keymap {
              compatible = "zmk,keymap";
 
              default_layer {
                     bindings = <
&kp ESC         &kp Q     &kp W     &kp E     &kp R    &kp T                               &kp Y     &kp U     &kp I      &kp O     &kp P      &kp MINUS 
&mt LCTL TAB    &kp A     &kp S     &kp D     &kp F    &kp G                               &kp H     &kp J     &kp K      &kp L     &kp SCLN   &kp QUOT
&kp LSFT        &kp Z     &kp X     &kp C     &kp V    &kp B      &mo ADJ      &trans      &kp N     &kp M     &kp CMMA   &kp DOT   &kp FSLH   &kp RET
&kp GLOBE       &btclr_ht 0 LCTL       &kp HOME  &kp END  &kp LALT  &kp LGUI  &kp SPC      &kp BKSP    &mo LWR   &mo RSE   &kp LARW   &kp DARW  &kp UARW   &kp RARW
                     >;
              };
              lower_layer {
                     bindings = <
&kp GRAV &kp N1    &kp N2    &kp N3    &kp N4    &kp N5                        &kp N6     &kp N7     &kp N8    &kp N9     &kp N0    &trans
&trans   &trans    &trans    &trans    &trans    &trans                        &kp LARW   &kp DARW   &kp UARW  &kp RARW   &trans    &trans
&trans   &trans    &trans    &trans    &trans    &trans    &trans    &trans    &trans     &trans     &trans    &trans     &trans    &trans
&trans   &trans    &trans    &trans    &trans    &trans    &trans    &trans    &trans     &trans     &trans    &trans     &trans    &trans
                     >;
              };
              raise_layer {
                     bindings = <
&kp GRAV &kp N1    &kp N2    &kp N3    &kp N4    &kp N5                        &kp N6      &kp N7    &kp N8    &kp N9     &kp N0     &trans
&trans   &trans    &trans    &trans    &trans    &trans                        &kp MINUS   &kp EQL   &kp LBKT  &kp RBKT   &kp BSLH   &trans
&trans   &trans    &trans    &trans    &trans    &trans    &trans    &trans    &kp MINUS   &kp EQL   &kp LBKT  &kp RBKT   &kp BSLH   &trans
&trans   &trans    &trans    &trans    &trans    &trans    &trans    &trans    &trans      &trans    &trans    &trans     &trans     &trans
                     >;
              };
              adjust_layer {
                     bindings = <
&bt BT_CLR   &bt BT_SEL 0 &bt BT_SEL 1 &bt BT_SEL 2 &bt BT_SEL 3 &bt BT_SEL 4                     &trans    &trans    &trans    &trans    &trans    &trans
&trans       &trans       &trans       &trans       &trans       &trans                           &trans    &trans    &trans    &trans    &trans    &trans
&trans       &trans       &trans       &trans       &trans       &trans       &trans    &trans    &trans    &trans    &trans    &trans    &trans    &trans
&trans       &trans       &trans       &trans       &trans       &trans       &trans    &trans    &trans    &trans    &trans    &trans    &trans    &trans
                     >;
              };
       };
};